{"record_id": "65", "source_file": "found.csv", "source_row": "66", "organization_name_original": "ADD Centre", "unresolved_q_identifier": "no", "input_website": "https://addcentre.com/", "final_website": "https://www.addcentre.com/", "canonical_website": "https://www.addcentre.com/", "normalized_domain": "addcentre.com", "original_status": "FOUND", "career_url": "https://www.addcentre.com/jobs-add-centre", "link_text": "Jobs", "score": "80", "ats_provider_detected": "", "evidence": "strong careers/jobs link text", "candidate_count": "1", "initial_classification": "likely_employer_career_page", "classification_reason": "Career-related link text or URL path", "retry_category": "", "recommended_next_action": "validate_page_and_extract_jobs", "processing_queue": "career_validation", "error": "", "organization_name_resolved": "", "ottawa_relationship": "", "ottawa_evidence": "", "validation_status": "unreviewed", "validation_notes": "", "last_processed": "2026-07-17", "checked_at_utc": "2026-07-17T21:24:09.820099+00:00", "requested_url": "https://www.addcentre.com/jobs-add-centre", "loaded_url": "https://www.addcentre.com/jobs-add-centre", "http_status": "200", "page_title": "Work With Us | Toronto & Mississauga | The ADD Centre", "detected_ats": "", "jsonld_jobposting_count": "0", "probable_job_link_count": "0", "sample_job_links": "", "validation_result": "probable_career_page_needs_review", "validation_reason": "Career language detected, but job state is unclear", "body_text_sample": "Skip to Main Content\nCall Now\n\nHome\n\nNeurofeedback\n\nOur Services\n\nResearch\n\nAbout Us\n\nContact Us\n\nJobs\n\nJob\n\nPsychologist Position\n\nPart Time Job\n\nVolunteer Position\n\nJob\n\nPart-Time Neurofeedback\nTrainer\nFind out more about our in-person brain training services.\nThe ADD Centre & The Biofeedback Institute of Toronto\nImprove your focus, reduce anxiety, and build resilience with our proven brain training approach.\n\n(905) 803-8066\n\naddcentre@gmail.com\n\nStart here:\nBrain Training\nBrain Mapping\nPsychoeducational Assessments\nComprehensive Assessments\nHRV Training\nCogmed Working Memory Training\nOptimal Performance Training\nRemote Training\n\nPrivacy Policy\n\nADD Centre Head Office\nin Mississauga:\n50 Village Centre Place\nSuite 200\nL4Z 1V9 \nMississauga, ON\n\nVisit us on Google\n\nADD Centre Toronto Office:\n3419-A Yonge Street, 2nd Floor\nM4N 2N1\nNorth York, Toronto, ON. \n\n© 2026 The ADD Centre & The Biofeedback Institute of Toronto\n\n×\nThis website uses cookies\nWe use cookies to personalize content and ads and to analyze our traffic. We also share information about your use of our site with our advertising and analytics partners who may combine it with other information you have provided to them or that they have collected from your use of their services. Privacy Policy\n SHOW DETAILS\nACCEPT ALL\nDECLINE ALL\nCOOKIE DECLARATION\nABOUT COOKIES\nStrictly necessary\nPerformance\nTargeting\nFunctionality\nUnclassified\nStrictly necessary cookies allow core website functionality such as user login and accoun", "crawl_error": "", "stage2_checked_at_utc": "2026-07-18T14:48:32.100410+00:00", "stage2_result": "confirmed_career_landing_unresolved", "stage2_reason": "Valid career landing page; downstream job source not resolved", "resolved_monitor_url": "https://www.addcentre.com/jobs-add-centre", "resolved_ats": "", "stage2_jsonld_jobposting_count": "0", "stage2_probable_job_link_count": "0", "stage2_sample_job_links": "", "candidate_urls_found": "60:https://www.addcentre.com/jobs | 60:https://www.addcentre.com/jobs-add-centre", "candidate_visits_json": "[{\"url\": \"https://www.addcentre.com/jobs\", \"result\": \"needs_manual_review\", \"ats\": \"\", \"score\": 60}]", "stage2_error": "", "stage2b_checked_at_utc": "2026-07-19T00:54:45.365921+00:00", "stage2b_result": "resolved_job_api", "stage2b_reason": "Job-like JSON or network response detected", "stage2b_monitor_url": "https://www.addcentre.com/jobs-add-