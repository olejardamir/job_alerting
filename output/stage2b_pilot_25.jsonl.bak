{"record_id": "99", "source_file": "found.csv", "source_row": "100", "organization_name_original": "Akran Marketing", "unresolved_q_identifier": "no", "input_website": "https://akran.com/", "final_website": "https://www.akran.com/", "canonical_website": "https://www.akran.com/", "normalized_domain": "akran.com", "original_status": "FOUND", "career_url": "https://www.akran.com/careers.htm", "link_text": "Careers", "score": "80", "ats_provider_detected": "", "evidence": "strong careers/jobs link text", "candidate_count": "1", "initial_classification": "likely_employer_career_page", "classification_reason": "Career-related link text or URL path", "retry_category": "", "recommended_next_action": "validate_page_and_extract_jobs", "processing_queue": "career_validation", "error": "", "organization_name_resolved": "", "ottawa_relationship": "", "ottawa_evidence": "", "validation_status": "unreviewed", "validation_notes": "", "last_processed": "2026-07-17", "checked_at_utc": "2026-07-17T21:25:37.671243+00:00", "requested_url": "https://www.akran.com/careers.htm", "loaded_url": "https://www.akran.com/careers.htm", "http_status": "200", "page_title": "Promotional Products Toronto & Ottawa | Akran Marketing â€“ Custom Branded Merchandise - Careers", "detected_ats": "", "jsonld_jobposting_count": "0", "probable_job_link_count": "0", "sample_job_links": "", "validation_result": "probable_career_page_needs_review", "validation_reason": "Career language detected, but job state is unclear", "body_text_sample": "Home\nAbout\nServices\nPro Tips\nPhilanthropy\nBlogs\nContact Us\n Search  Sign In  Cart  EN\n613.739.4000 · 888.462.5726 sales@akran.com\nBlack Loon\nGraduation Swag 2026\nBrands\nApparel\nAwards\nBags\nDrinkware\nFun\nHeadwear\nHealth\nMore\nCareers\nHome\nCareers\n\nEvery day we create innovative and effective branding products and partnerships for small, medium, and large clients in the private and public sector — and we love what we do. The key to our success has always been our focus on teamwork, providing each client the resources they need to succeed in marketing their brand. \n\nAkran Marketing is an award-winning, customer-driven company. We have been a leader in the premium product industry since 1997.  Today other marketing companies follow Akran – we are a great Canadian success story.  The Advertising Specialty Institute (ASI) recently announced Akran Marketing is the fastest growing branding company and one of the ‘Best Places to Work in North America’.\n\nWe are looking to expand our Dynamic Customer Service and Sales team. \n\nWhether you're just at the beginning of your professional journey or a seasoned expert in your field, Akran Marketing offers a range of employment opportunities with considerable room for career advancement.\n\nAkran is a great place to achieve personal and professional growth. As our business continues to expand, so does our list of available opportunities. If you have creative talent and a deep commitment to excellence, we would love to hear from you.  Are you up to", "crawl_error": "", "stage2_checked_at_utc": "2026-07-18T14:49:00.712952+00:00", "stage2_result": "confirmed_career_landing_unresolved", "stage2_reason": "Valid career landing page; downstream job source not resolved", "resolved_monitor_url": "https://www.akran.com/careers.htm", "resolved_ats": "", "stage2_jsonld_jobposting_count": "0", "stage2_probable_job_link_count": "0", "stage2_sample_job_links": "", "candidate_urls_found": "60:https://www.akran.com/careers.htm", "candidate_visits_json": "[]", "stage2_error": "", "stage2b_checked_at_utc": "2026-07-19T00:55:36.127556+00:00", "stage2b_result": "career_page_still_unresolved", "stage2b_reason": "Career page confirmed, but no downstream listing or job API was found", "stage2b_monitor_url": "https://www.akran.com/careers.htm", "stage2b_provider": "", "stage2b_job_api_url": "", "stage2b_network_candidate_count": 1, "stage2b_network_candidates_json": "[{\"url\": \"https://www.akran.co