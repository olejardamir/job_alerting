{"record_id": "133", "source_file": "found.csv", "source_row": "134", "organization_name_original": "Algonquin Power", "unresolved_q_identifier": "no", "input_website": "https://algonquinpower.com/", "final_website": "https://algonquinpower.com/", "canonical_website": "https://algonquinpower.com/", "normalized_domain": "algonquinpower.com", "original_status": "FOUND", "career_url": "https://algonquinpower.com/careers.html", "link_text": "Careers", "score": "80", "ats_provider_detected": "", "evidence": "strong careers/jobs link text", "candidate_count": "1", "initial_classification": "likely_employer_career_page", "classification_reason": "Career-related link text or URL path", "retry_category": "", "recommended_next_action": "validate_page_and_extract_jobs", "processing_queue": "career_validation", "error": "", "organization_name_resolved": "", "ottawa_relationship": "", "ottawa_evidence": "", "validation_status": "unreviewed", "validation_notes": "", "last_processed": "2026-07-17", "checked_at_utc": "2026-07-17T21:26:55.887352+00:00", "requested_url": "https://algonquinpower.com/careers.html", "loaded_url": "https://algonquinpower.com/careers.html", "http_status": "200", "page_title": "Careers", "detected_ats": "", "jsonld_jobposting_count": "0", "probable_job_link_count": "0", "sample_job_links": "", "validation_result": "probable_career_page_needs_review", "validation_reason": "Career language detected, but job state is unclear", "body_text_sample": "Skip to main content\nAbout Us\nInvestors\nNews & Media\nCareers\nContact\nCareers\n\nWe understand that the environment we create for our people must reflect our corporate values: make a positive difference, do the right thing, and think creatively.\n\nWe aim to create a corporate culture where our people feel safe, motivated and supported in every aspect of their job role. We strive for our people to work within a culture that fosters innovative thoughts, the freedom to try new things and the support of senior leadership to do so.\n\nIt is understood by Algonquin and its subsidiaries that, by providing support, recognition and freedom to act, the potential of our organization as a whole is limitless.\n\nJoin our team\n\nIn order to view a full list of job opportunities you will be redirected to the Liberty career site.\n\nSearch opportunities\nRecruitment fraud alert\n\nWe want to bring to your notice that Liberty follows extensive recruitment screening steps. Liberty does not charge/accept any amount or security deposit from job seekers during the recruitment process.\n\nWe have observed that there has been an increase in recruitment fraud involving scammers who post fraudulent jobs openings or contact job-seekers with fake job offers. These individuals sometimes even conduct fraudulent interviews to obtain personal information or money from the applicants. We have also noticed that specific individuals claiming to be from the Liberty Recruitment function are contacting prospective candidates pr", "crawl_error": "", "stage2_checked_at_utc": "2026-07-18T14:50:33.337977+00:00", "stage2_result": "confirmed_career_landing_unresolved", "stage2_reason": "Valid career landing page; downstream job source not resolved", "resolved_monitor_url": "https://algonquinpower.com/careers.html", "resolved_ats": "", "stage2_jsonld_jobposting_count": "0", "stage2_probable_job_link_count": "0", "stage2_sample_job_links": "", "candidate_urls_found": "70:https://jobs.libertyenergyandwater.com/ | 60:https://algonquinpower.com/careers.html#main-content", "candidate_visits_json": "[{\"url\": \"https://jobs.libertyenergyandwater.com/\", \"result\": \"needs_manual_review\", \"ats\": \"\", \"score\": 70}]", "stage2_error": "", "stage2b_checked_at_utc": "2026-07-19T00:58:14.313179+00:00", "stage2b_result": "career_page_still_unresolved", "stage2b_reason": "Career page confirmed, but no downstream listing or job API was found", "stage2b_monitor_url": "https://algonquinpower.com/careers.html", "stage2b_pro