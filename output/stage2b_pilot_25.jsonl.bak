{"record_id": "20", "source_file": "found.csv", "source_row": "21", "organization_name_original": "ABCO Industries Lunenburg Shipyard", "unresolved_q_identifier": "no", "input_website": "https://abco.ca/", "final_website": "https://abco.ca/", "canonical_website": "https://abco.ca/", "normalized_domain": "abco.ca", "original_status": "FOUND", "career_url": "https://abco.ca/careers/", "link_text": "Careers", "score": "140", "ats_provider_detected": "", "evidence": "strong careers/jobs link text; careers/jobs URL path", "candidate_count": "1", "initial_classification": "likely_employer_career_page", "classification_reason": "Career-related link text or URL path", "retry_category": "", "recommended_next_action": "validate_page_and_extract_jobs", "processing_queue": "career_validation", "error": "", "organization_name_resolved": "", "ottawa_relationship": "", "ottawa_evidence": "", "validation_status": "unreviewed", "validation_notes": "", "last_processed": "2026-07-17", "checked_at_utc": "2026-07-17T21:22:06.566630+00:00", "requested_url": "https://abco.ca/careers/", "loaded_url": "https://abco.ca/careers/", "http_status": "200", "page_title": "Careers - ABCO", "detected_ats": "", "jsonld_jobposting_count": "0", "probable_job_link_count": "0", "sample_job_links": "", "validation_result": "probable_career_page_needs_review", "validation_reason": "Career language detected, but job state is unclear", "body_text_sample": "Skip to content\nHome\nIndustries\nAbout ABCO\nResources\nCareers\nContact\nDiscuss Your Project\nHOME / CAREERS\nJOIN OUR TEAM\n\nBuild your career working on real engineering challenges — where precision, accountability, and performance matter.\n\nWhy Work At ABCO\nA CULTURE OF EXCELLENCE\n\n\nWe work on projects that require precision, accountability, and real problem-solving.\n\nWhether in engineering, fabrication, or operations, every role contributes directly to building solutions that perform in demanding environments.\n\nAt ABCO, you’re not just part of a team — you’re part of delivering work that matters.\n\n“Having the right attitude is very important. If you have the right attitude, we’re willing to train and promote you. We’ll provide what you need to do your job properly. ”\n\n— GRAHAM GERHARDT – PRESIDENT, ABCO\n\nOpen Positions\nCURRENT OPPORTUNITIES\nFABRICATOR/WELDER\nFULL-TIME // LUNENBURG, NS\nNAVAL ARCHITECT\nFULL-TIME // LUNENBURG, NS\nMACHINIST\nFULL-TIME // LUNENBURG, NS\nMARINE ELECTRICIAN\nFULL-TIME // LUNENBURG, NS\nLABOURER\nFULL-TIME // LUNENBURG, NS\n\n81 TANNERY ROAD LUNENBURG, NOVA SCOTIA, CANADA B0J 2C0\n\n(866) 634-8821\n\nINFO@ABCO.CA\n\nWHAT WE DO\nAluminum Vessels\nIndustrial Systems\nEnvironmental\nCOMPANY\nAbout ABCO\nWhy ABCO\nCareers – Open Positions\nGET IN TOUCH\n\nDon’t miss the latest news\n\nReceive ABCO News\n\n© 2026 ABCO Industries. All rights reserved.\n\nPrivacy Policy | Terms of Service", "crawl_error": "", "stage2_checked_at_utc": "2026-07-18T14:46:43.680937+00:00", "stage2_result": "confirmed_career_landing_unresolved", "stage2_reason": "Valid career landing page; downstream job source not resolved", "resolved_monitor_url": "https://abco.ca/careers/", "resolved_ats": "", "stage2_jsonld_jobposting_count": "0", "stage2_probable_job_link_count": "0", "stage2_sample_job_links": "", "candidate_urls_found": "60:https://abco.ca/careers/#main", "candidate_visits_json": "[]", "stage2_error": "", "stage2b_checked_at_utc": "2026-07-19T00:51:09.357050+00:00", "stage2b_result": "career_page_still_unresolved", "stage2b_reason": "Career page confirmed, but no downstream listing or job API was found", "stage2b_monitor_url": "https://abco.ca/careers/", "stage2b_provider": "", "stage2b_job_api_url": "", "stage2b_network_candidate_count": 1, "stage2b_network_candidates_json": "[{\"url\": \"https://abco.ca/careers/\", \"status\": 200, \"resource_type\": \"document\", \"content_type\": \"text/html; charset=UTF-8\", \"score\": 65, \"structured_job_score\": 0, \"platform\": \"\", \"body_