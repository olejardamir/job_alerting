{"record_id": "154", "source_file": "found.csv", "source_row": "155", "organization_name_original": "Alliance française d'Edmonton", "unresolved_q_identifier": "no", "input_website": "https://afedmonton.com/", "final_website": "https://www.afedmonton.com/en/", "canonical_website": "https://www.afedmonton.com/en/", "normalized_domain": "afedmonton.com", "original_status": "FOUND", "career_url": "https://www.afedmonton.com/en/about/careers/", "link_text": "Careers", "score": "140", "ats_provider_detected": "", "evidence": "strong careers/jobs link text; careers/jobs URL path", "candidate_count": "1", "initial_classification": "likely_employer_career_page", "classification_reason": "Career-related link text or URL path", "retry_category": "", "recommended_next_action": "validate_page_and_extract_jobs", "processing_queue": "career_validation", "error": "", "organization_name_resolved": "", "ottawa_relationship": "", "ottawa_evidence": "", "validation_status": "unreviewed", "validation_notes": "", "last_processed": "2026-07-17", "checked_at_utc": "2026-07-17T21:27:36.951334+00:00", "requested_url": "https://www.afedmonton.com/en/about/careers/", "loaded_url": "https://www.afedmonton.com/en/about/careers/", "http_status": "200", "page_title": "Alliance Francaise d'Edmonton - Careers", "detected_ats": "", "jsonld_jobposting_count": "0", "probable_job_link_count": "0", "sample_job_links": "", "validation_result": "probable_career_page_needs_review", "validation_reason": "Career language detected, but job state is unclear", "body_text_sample": "Login\nBecome a Member\nFR    Receive Our Newsletter    Student Portal\nLearn French\nCamps 2026\nExams\nCultural Events\nLibrary\nAbout\nEN › About › Careers\nJoin the team!\n\nCheck out our job and internship offers.\n\n\n\n\n\n\n\n\n\n\nJob offers\n\n\n\n\n\n\n  FLE/FLS Teachers\n\nTeachers: We are always looking for individuals available on Saturdays and weekday evenings to teach classes.\n\n\nIf you have a valid work permit, permanent residency, or Canadian citizenship and experience teaching French as a Foreign or Second Language (FLE/FSL), we would love to hear from you!\nPlease send your CV, cover letter, and a letter of recommendation by email to our Educational Director, at  ecole@afedmonton.ca. (Only candidates selected for an interview will be contacted.)\n\n\n\n\n\n\n\n\n\n\n\n\nLearn French in your city\n\n 10424 123 St, T5N 1N7\n\n 587-852-4575\n\n info@afedmonton.ca\n\n\n\nStudent portal \n\n\n\n\n\n\n\n\n\n\n\n\n\n\nLand acknowledgement\n\nThe Alliance Française of Edmonton respectfully acknowleges that we are situated on Treaty 6 territory, traditional lands of First Nations and Métis people.\n\nDesign by Monsieur Graphic", "crawl_error": "", "stage2_checked_at_utc": "2026-07-18T14:50:51.116837+00:00", "stage2_result": "confirmed_career_landing_unresolved", "stage2_reason": "Valid career landing page; downstream job source not resolved", "resolved_monitor_url": "https://www.afedmonton.com/en/about/careers/", "resolved_ats": "", "stage2_jsonld_jobposting_count": "0", "stage2_probable_job_link_count": "0", "stage2_sample_job_links": "", "candidate_urls_found": "115:https://www.afedmonton.com/en/about/careers/", "candidate_visits_json": "[]", "stage2_error": "", "stage2b_checked_at_utc": "2026-07-19T00:59:55.587072+00:00", "stage2b_result": "career_page_still_unresolved", "stage2b_reason": "Career page confirmed, but no downstream listing or job API was found", "stage2b_monitor_url": "https://www.afedmonton.com/en/about/careers/", "stage2b_provider": "", "stage2b_job_api_url": "", "stage2b_network_candidate_count": 1, "stage2b_network_candidates_json": "[{\"url\": \"https://www.afedmonton.com/en/about/careers/\", \"status\": 200, \"resource_type\": \"document\", \"content_type\": \"text/html; charset=utf-8\", \"score\": 65, \"structured_job_score\": 0, \"platform\": \"\", \"body_sample\": \"<!doctype html>\\n<html lang=\\\"en\\\">\\n\\t<head>\\r\\n\\t<!-- Powered by https://www.on