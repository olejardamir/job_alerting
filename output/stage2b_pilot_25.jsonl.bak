{"record_id": "130", "source_file": "found.csv", "source_row": "131", "organization_name_original": "Alchemy (Canada)", "unresolved_q_identifier": "no", "input_website": "https://alchemynano.com/", "final_website": "https://www.alchemynano.com/", "canonical_website": "https://www.alchemynano.com/", "normalized_domain": "alchemynano.com", "original_status": "FOUND", "career_url": "https://www.alchemynano.com/careers", "link_text": "Careers at AlchemyView currently open positions at Alchemy.", "score": "140", "ats_provider_detected": "", "evidence": "strong careers/jobs link text; careers/jobs URL path", "candidate_count": "2", "initial_classification": "likely_employer_career_page", "classification_reason": "Career-related link text or URL path", "retry_category": "", "recommended_next_action": "validate_page_and_extract_jobs", "processing_queue": "career_validation", "error": "", "organization_name_resolved": "", "ottawa_relationship": "", "ottawa_evidence": "", "validation_status": "unreviewed", "validation_notes": "", "last_processed": "2026-07-17", "checked_at_utc": "2026-07-17T21:26:51.484416+00:00", "requested_url": "https://www.alchemynano.com/careers", "loaded_url": "https://www.alchemynano.com/careers", "http_status": "200", "page_title": "Careers at Alchemy", "detected_ats": "", "jsonld_jobposting_count": "0", "probable_job_link_count": "0", "sample_job_links": "", "validation_result": "probable_career_page_needs_review", "validation_reason": "Career language detected, but job state is unclear", "body_text_sample": "Our Innovations\nAutomotive\nDefence\nWho we are\nWork with Us\nCareers at Alchemy\nJoin Our Team\nWe're building a category-defining nanotechnology company, join a team of driven builders turning big ideas into real-world impact.\nMake an impact.\nEverything you do directly impacts the success of our company, your peers, and your own growth.\nCompetitive Benefits.\nYour health and well being always comes first at Alchemy with our competitive benefits and vacation packages.\nWe're transforming legacy industries from the nanoscale up.\nWe're a team made up of passionate people. Every member of our team has made an impact on where we are today. If you want to make a difference, we'd love to talk to you.\nView Open Positions\nFlexible working environment.\nWe focus on results, not rigid schedules.We trust you to manage your time and deliver your best work.\nYou matter.\nWe take your growth as seriously as we take the solutions we build. Your voice and your wellbeing matter here.\nAccelerate your career.\nBecome our resident expert in your field and develop your technical, professional, and personal skills in real time.\nBuilt on collaboration.\nWe build systems that keep teams working closely together, with strong collaboration across roles and disciplines.\nOpen Positions\nCareers at Alchemy\nInterested in working with us but don't see a position that fits? We're always looking for talented, hard-working people! Reach out to us at team@alchemynano.com\nVertically integrated nanotechnology.\nHome\nOur Inno", "crawl_error": "", "stage2_checked_at_utc": "2026-07-18T14:50:21.230674+00:00", "stage2_result": "confirmed_career_landing_unresolved", "stage2_reason": "Valid career landing page; downstream job source not resolved", "resolved_monitor_url": "https://www.alchemynano.com/careers", "resolved_ats": "", "stage2_jsonld_jobposting_count": "0", "stage2_probable_job_link_count": "0", "stage2_sample_job_links": "", "candidate_urls_found": "60:https://www.alchemynano.com/careers#Top", "candidate_visits_json": "[]", "stage2_error": "", "stage2b_checked_at_utc": "2026-07-19T00:57:48.916982+00:00", "stage2b_result": "career_page_still_unresolved", "stage2b_reason": "Career page confirmed, but no downstream listing or job API was found", "stage2b_monitor_url": "https://www.alchemynano.com/careers", "stage2b_provider": "", "stage2b_job_api_url": "", "stage2b_network_candidate_count": 1, "stage2b_network_candidates_json"