{"record_id": "128", "source_file": "found.csv", "source_row": "129", "organization_name_original": "Alcohol Countermeasure Systems (Canada)", "unresolved_q_identifier": "no", "input_website": "https://acs-corp.com/", "final_website": "https://acs-corp.com/", "canonical_website": "https://acs-corp.com/", "normalized_domain": "acs-corp.com", "original_status": "FOUND", "career_url": "https://acs-corp.com/careers", "link_text": "Careers", "score": "140", "ats_provider_detected": "", "evidence": "strong careers/jobs link text; careers/jobs URL path", "candidate_count": "1", "initial_classification": "likely_employer_career_page", "classification_reason": "Career-related link text or URL path", "retry_category": "", "recommended_next_action": "validate_page_and_extract_jobs", "processing_queue": "career_validation", "error": "", "organization_name_resolved": "", "ottawa_relationship": "", "ottawa_evidence": "", "validation_status": "unreviewed", "validation_notes": "", "last_processed": "2026-07-17", "checked_at_utc": "2026-07-17T21:26:46.826961+00:00", "requested_url": "https://acs-corp.com/careers", "loaded_url": "https://acs-corp.com/careers", "http_status": "200", "page_title": "ACS group of companies", "detected_ats": "", "jsonld_jobposting_count": "0", "probable_job_link_count": "0", "sample_job_links": "", "validation_result": "probable_career_page_needs_review", "validation_reason": "Career language detected, but job state is unclear", "body_text_sample": "Solutions\nProducts\nCompany\nNews and events\nSupport\nInnovations Careers Contact\nBe part of saving lives\n\n   Watch the video\n\nThe road to your rewarding career starts here\n\n\n\n\nACS is a leading designer, manufacturer, and distributer of ignition interlocks, breath alcohol testers, and drug testing products.\n\n\n\n\nWe are constantly looking to add team members who are ambitious, creative, committed and passionate about their work – people just like you! Take the next step in your career, join a team that listens to your ideas and makes them a reality.\n\nAvailable positions\nWe embrace diversity\n\nAs an international company, our workforce reflects the diversity of the international community. We value and encourage the unique perspectives of our diverse team members.\n\nOur culture\n\nRespect, learn, and collaborate are the three words we feel summarize our unique culture. Our success depends on your success; we like to promote from within and encourage every employee to discuss and pursue their individual career goals.\n\nRespect\n\nWe believe in ethical standards, core values, and maintaining positive and respectful relationships. All opinions are important to us and we have an open door policy so anyone can share ideas, seek guidance, discuss concerns and learn from each other.\n\nLearn\n\nWe encourage continuous learning and career growth through our education assistance program, job related seminars and informal mentorships. We also believe we learn the most valuable lessons from each other s", "crawl_error": "", "stage2_checked_at_utc": "2026-07-18T14:50:27.425589+00:00", "stage2_result": "confirmed_career_landing_unresolved", "stage2_reason": "Valid career landing page; downstream job source not resolved", "resolved_monitor_url": "https://acs-corp.com/careers", "resolved_ats": "", "stage2_jsonld_jobposting_count": "0", "stage2_probable_job_link_count": "0", "stage2_sample_job_links": "", "candidate_urls_found": "115:https://acs-corp.com/careers | 60:https://acs-corp.com/index.php?route=information/career/#positions | 60:https://acs-corp.com/index.php?route=information/career/canada#positions", "candidate_visits_json": "[{\"url\": \"https://acs-corp.com/index.php?route=information/career/#positions\", \"result\": \"confirmed_career_landing_unresolved\", \"ats\": \"\", \"score\": 60}, {\"url\": \"https://acs-corp.com/index.php?route=information/career/canada#positions\", \"result\": \"confirmed_career_landing_unresolved\", \"ats\": \"\", \"score\": 60