{"record_id": "147", "source_file": "found.csv", "source_row": "148", "organization_name_original": "All Saints Lutheran Church", "unresolved_q_identifier": "no", "input_website": "https://allsaintslutheran.ca/", "final_website": "https://www.allsaintslutheran.ca/", "canonical_website": "https://www.allsaintslutheran.ca/", "normalized_domain": "allsaintslutheran.ca", "original_status": "FOUND", "career_url": "https://www.allsaintslutheran.ca/pages/jobs-at-aslc", "link_text": "Join Our Team", "score": "80", "ats_provider_detected": "", "evidence": "strong careers/jobs link text", "candidate_count": "2", "initial_classification": "likely_employer_career_page", "classification_reason": "Career-related link text or URL path", "retry_category": "", "recommended_next_action": "validate_page_and_extract_jobs", "processing_queue": "career_validation", "error": "", "organization_name_resolved": "", "ottawa_relationship": "", "ottawa_evidence": "", "validation_status": "unreviewed", "validation_notes": "", "last_processed": "2026-07-17", "checked_at_utc": "2026-07-17T21:27:28.782424+00:00", "requested_url": "https://www.allsaintslutheran.ca/pages/jobs-at-aslc", "loaded_url": "https://www.allsaintslutheran.ca/pages/jobs-at-aslc", "http_status": "200", "page_title": "Jobs at ASLC | Who We Are | All Saints Lutheran Church", "detected_ats": "", "jsonld_jobposting_count": "0", "probable_job_link_count": "0", "sample_job_links": "", "validation_result": "probable_career_page_needs_review", "validation_reason": "Career language detected, but job state is unclear", "body_text_sample": "Search\nContact\nHOME\nEVENTS\nNEWS\nSERMONS\nWHO WE ARE\nOUR MINISTRIES\nWE PRAY\nWE GIVE\nJOIN OUR TEAM\nApply Now\nJoin our Team\nAbout Us\n \nI'm New\n \nOur Team\n \nOur Beliefs\n \nJobs at ASLC\n\nCurrent opening - Lead Pastor Position\n\nWe are prayerfully seeking a Spirit-filled, full-time Pastor to provide spiritual leadership preach and teach God’s Word, shepherd the congregation, and equip believers for discipleship and service.\n\nThe Pastor will serve as both spiritual leader and ministry partner, working collaboratively with the Church Council, ministry leaders, and congregation to nurture spiritual growth and advance the mission of the church.\n\n \n\nApply Now\n\nDownloads\nNew Job Posting - Lead Pastor (ASLC).pdf\nSign up for our Newsletter\nSubscribe to receive email updates with the latest news.\nEnter Your Email\n Subscribe\nLocation\n1061 Pinecrest Rd.\nOttawa, ON\nK2B 6B7\nView on Google Maps\nContact\nEmail:\n\"ASLC Office\"secretary@allsaintslutheran.ca\nOffice Hours\n\nSummer Office hours:\nMonday - 9:30 AM - noon - By appointment ONLY\nTuesday - 10:30 AM - noon - By appointment ONLY\nWednesday - 9:30 AM -noon - Walk-in\nFriday - 10:30 AM - 2:30 PM - By appointment ONLY\n\nMenu\nHome\nEvents\nNews\nSermons\nWho We Are\nOUR MINISTRIES\nWe Pray\nWe Give\nJoin Our Team\nAbout\nAbout Us\nI'm New\nOur Team\nOur Beliefs\nJobs at ASLC\n© 2026 All Saints Lutheran Church. All Rights Reserved. | Login\npowered by\nWebsite Developed by Tithely", "crawl_error": "", "stage2_checked_at_utc": "2026-07-18T14:50:48.609226+00:00", "stage2_result": "confirmed_career_landing_unresolved", "stage2_reason": "Valid career landing page; downstream job source not resolved", "resolved_monitor_url": "https://www.allsaintslutheran.ca/pages/jobs-at-aslc", "resolved_ats": "", "stage2_jsonld_jobposting_count": "0", "stage2_probable_job_link_count": "0", "stage2_sample_job_links": "", "candidate_urls_found": "60:https://www.allsaintslutheran.ca/pages/jobs-at-aslc | 60:https://www.allsaintslutheran.ca/who-we-are/pages/jobs-at-aslc", "candidate_visits_json": "[{\"url\": \"https://www.allsaintslutheran.ca/who-we-are/pages/jobs-at-aslc\", \"result\": \"confirmed_career_landing_unresolved\", \"ats\": \"\", \"score\": 60}]", "stage2_error": "", "stage2b_checked_at_utc": "2026-07-19T00:59:43.701884+00:00", "stage2b_result": "career_page_still_unresolved", "stage2b_reason": "Car