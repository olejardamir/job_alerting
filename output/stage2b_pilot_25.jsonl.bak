{"record_id": "48", "source_file": "found.csv", "source_row": "49", "organization_name_original": "Acera Services Ltd (formerly Smith Petrie Carr & Scott)", "unresolved_q_identifier": "no", "input_website": "https://acera.ca/", "final_website": "https://acera.ca/", "canonical_website": "https://acera.ca/", "normalized_domain": "acera.ca", "original_status": "FOUND", "career_url": "https://acera.ca/careers/", "link_text": "Careers", "score": "140", "ats_provider_detected": "", "evidence": "strong careers/jobs link text; careers/jobs URL path", "candidate_count": "1", "initial_classification": "likely_employer_career_page", "classification_reason": "Career-related link text or URL path", "retry_category": "", "recommended_next_action": "validate_page_and_extract_jobs", "processing_queue": "career_validation", "error": "", "organization_name_resolved": "", "ottawa_relationship": "", "ottawa_evidence": "", "validation_status": "unreviewed", "validation_notes": "", "last_processed": "2026-07-17", "checked_at_utc": "2026-07-17T21:23:20.145062+00:00", "requested_url": "https://acera.ca/careers/", "loaded_url": "https://acera.ca/careers/", "http_status": "200", "page_title": "Careers at Acera Insurance | See Current Opportunities", "detected_ats": "", "jsonld_jobposting_count": "0", "probable_job_link_count": "0", "sample_job_links": "", "validation_result": "probable_career_page_needs_review", "validation_reason": "Career language detected, but job state is unclear", "body_text_sample": "Skip to content\n\nAcera Insurance and Navacord have united to provide Canadians with greater choice and solutions. Learn more.\n\n×\nPersonal\nBusiness\nBenefits\nFind a Branch\nClaims\nPayments\nCareers\nContact\nSelect your region\nRegion\nAB\nBC\nMB\nNB\nNL\nNT\nNS\nNU\nON\nPE\nQC\nSK\nYT\nAUTO & RECREATIONAL\nHOME & PROPERTY\nLIFE, HEALTH & TRAVEL\nGET A QUOTE\n\nCareers at Acera Insurance\n\nChanging the way people feel about a career in insurance.\n\nChoose a career that empowers you to excel in and take ownership of your work, while having fun. Choose a career with Acera Insurance — we put people first!\n\nSee Current Opportunities\n(opens in a new tab)\nBe a part of our growing team.\n\nAs an employer of choice, Acera Insurance offers an outstanding workplace and employee culture that creates valuable opportunities for all of our employees.\n\nChoosing a career with Acera Insurance means you’ll be:\n\nEncouraged to challenge the status quo and never stop learning in your commitment to excellence.\nEmpowered with a sense of accountability and autonomy to take ownership of your work.\nTreated with respect as we put our people first.\nRecognized for your achievements and engaged in festivities — big and small — that make work fun.\n\nIf this sounds good to you, come join our network of more than 1,300 professionals.\n\nAbout Acera Insurance\n\nAs the largest independent, employee-controlled brokerage in Canada, we provide our employees with a unique opportunity to change the way people feel about insurance. That’s because we", "crawl_error": "", "stage2_checked_at_utc": "2026-07-18T14:47:46.672904+00:00", "stage2_result": "confirmed_career_landing_unresolved", "stage2_reason": "Valid career landing page; downstream job source not resolved", "resolved_monitor_url": "https://acera.ca/careers/", "resolved_ats": "", "stage2_jsonld_jobposting_count": "0", "stage2_probable_job_link_count": "0", "stage2_sample_job_links": "", "candidate_urls_found": "70:https://careers.acera.ca/?_gl=1*8n0co6*_ga*MTQ2MTMwOTA3Ni4xNzA0MjM0NjQw*_ga_TKPVE0V8BR*MTcxMjA5NzQ3MS42OS4wLjE3MTIwOTc0NzEuMC4wLjA | 60:https://acera.ca/careers/#content", "candidate_visits_json": "[{\"url\": \"https://careers.acera.ca/?_gl=1*8n0co6*_ga*MTQ2MTMwOTA3Ni4xNzA0MjM0NjQw*_ga_TKPVE0V8BR*MTcxMjA5NzQ3MS42OS4wLjE3MTIwOTc0NzEuMC4wLjA\", \"result\": \"confirmed_career_landing_unresolved\", \"ats\": \"\", \"score\": 70}]", "stage2_error": "", "stage2b_checked_at_utc": "2026-07-19T00:52:41.479176+00