{"record_id": "16", "source_file": "found.csv", "source_row": "17", "organization_name_original": "5N Plus Inc.", "unresolved_q_identifier": "no", "input_website": "https://5nplus.com/", "final_website": "https://www.5nplus.com/en/", "canonical_website": "https://www.5nplus.com/en/", "normalized_domain": "5nplus.com", "original_status": "FOUND", "career_url": "https://www.5nplus.com/en/career/", "link_text": "Careers", "score": "140", "ats_provider_detected": "", "evidence": "strong careers/jobs link text; careers/jobs URL path", "candidate_count": "1", "initial_classification": "likely_employer_career_page", "classification_reason": "Career-related link text or URL path", "retry_category": "", "recommended_next_action": "validate_page_and_extract_jobs", "processing_queue": "career_validation", "error": "", "organization_name_resolved": "", "ottawa_relationship": "", "ottawa_evidence": "", "validation_status": "unreviewed", "validation_notes": "", "last_processed": "2026-07-17", "checked_at_utc": "2026-07-17T21:22:00.826135+00:00", "requested_url": "https://www.5nplus.com/en/career/", "loaded_url": "https://www.5nplus.com/en/career/", "http_status": "200", "page_title": "Career | 5N Plus", "detected_ats": "", "jsonld_jobposting_count": "0", "probable_job_link_count": "0", "sample_job_links": "", "validation_result": "probable_career_page_needs_review", "validation_reason": "Career language detected, but job state is unclear", "body_text_sample": "Careers\nContact us\nFrançais\nDeutsch\nAbout Us\nMarkets\nProducts\nInnovation\nSustainability\nInvestors\nNews\nDEUTSCH\nHome \nCareer\nCareers\nJoin our team!\n\nAt 5N Plus we are building a culture of innovation, collaboration and growth. We are looking for passionate individuals ready to make an impact. Explore our open positions and submit your application today.\n\nOUR JOB POSTINGS\nWhy Work at 5N Plus?\n\nAt 5N Plus, our mission is to be critical to our customers, valued by our employees and trusted by our shareholders. Find out more about how this translates in our day-to-day work and corporate culture\n\nOur\nCulture\nCareer Development\n\nTo ensure we have the talented resources we need to realise our vision, we provide stimulating career opportunities, training, continuous learning through projects and assignments to our people to develop and prepare for their next challenge.\n\nA Preferred Employer, Driving Innovation\n\nSuccess starts with the right talent and we are fortunate to have some of the best resources in our industry to generate innovative ideas for our customers. This, combined with a high level of employee engagement, enables us to efficiently deliver high quality products to our clients and prepare for future business opportunities.\n\nRespect in Meeting Employee Needs\n\nWe respect the cultural, historical and regional differences at all our global locations and we ask our people what they want and need through employee surveys, focus groups and informal meetings. We ask what we are", "crawl_error": "", "stage2_checked_at_utc": "2026-07-18T14:46:38.603760+00:00", "stage2_result": "confirmed_career_landing_unresolved", "stage2_reason": "Valid career landing page; downstream job source not resolved", "resolved_monitor_url": "https://www.5nplus.com/en/career/", "resolved_ats": "", "stage2_jsonld_jobposting_count": "0", "stage2_probable_job_link_count": "0", "stage2_sample_job_links": "", "candidate_urls_found": "115:https://www.5nplus.com/en/career/ | 60:https://www.5nplus.com/en/career/jobs-list/", "candidate_visits_json": "[{\"url\": \"https://www.5nplus.com/en/career/jobs-list/\", \"result\": \"confirmed_career_landing_unresolved\", \"ats\": \"\", \"score\": 60}]", "stage2_error": "", "stage2b_checked_at_utc": "2026-07-19T00:50:41.513006+00:00", "stage2b_result": "resolved_job_api", "stage2b_reason": "Job-like JSON or network response detected", "stage2b_monitor_url": "https://www.5nplus.com/en/career/", "stage2b_provider": "", "stage2b_job_api_url": "https